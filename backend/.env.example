APP_NAME=flypy-typing-backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/flypy_typing
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
SMTP_SUBJECT_PREFIX=[Flypy] 
SMTP_FALLBACK_ENABLED=false
SMTP_FALLBACK_HOST=
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_USERNAME=
SMTP_FALLBACK_PASSWORD=
SMTP_FALLBACK_FROM=
SMTP_FALLBACK_USE_TLS=true
SMTP_FALLBACK_USE_SSL=false

OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=flypy-assets
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
CHAT_PROVIDER=openai
